{
  "manifest_version": 2,
  "name": "chaotic timer",
  "version": "0.1",

  "description": "A timer extension that makes it difficult to end your session.",
  "browser_specific_settings": {
    "gecko": {
      "id": "chaotic-timer@yourname",
      "strict_min_version": "58.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },

  "icons": {
    "48": "images/clock.png",
    "96": "images/clock.png"
  },


  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["chaotic_clock.js"]
    }
  ],
  "web_accessible_resources": [
    "screen_overlay.js",
    "box.js",
    "challenges/*",
    "images/*",
    "sounds/*"
  ],
  "browser_action": {
    "default_icon": "./images/clock.png",
    "default_title": "Chaotic Timer",
    "default_popup": "./popup/popup.html"
  },
  "background": {
    "scripts": ["background.js", "redirect.js", "endsession.js"],
    "persistent": true
  },
  "permissions": [
    "webRequest",
    "tabs",
    "webRequestBlocking",
    "<all_urls>",
    "storage",
    "tabs",
    "activeTab"
  ]
}